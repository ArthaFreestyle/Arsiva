{
    "app":{
        "name" : "Arsiva",
        "version" : "1.0.0",
        "trust_proxy" : true,
        "rate_limit" : {
            "max" : 10,
            "expiration_seconds" : 60
        }
    },
    "web" :{
        "prefork" : false,
        "port" : 3000
    },
    "database" : {
        "postgres" : {
            "host" : "localhost",
            "port" : 5432,
            "user" : "NAMA_USER_POSTGRES",
            "password" : "PASSWORD_POSTGRES",
            "dbname" : "NAMA_DB_POSTGRES"
        },
        "redis" : {
            "host" : "localhost",
            "port" : 6379,
            "password" : "PASSWORD_REDIS",
            "db" : 0
        }
    },
    "log" : {
        "level" : 5,
        "file" : "./logs/arsiva.log",
        "max_size_mb" : 50,
        "max_backups" : 7,
        "max_age_days" : 30,
        "compress" : true
    },
    "email" : {
        "host" : "localhost",
        "port" : 25,
        "username" : "admin@arsiva.id",
        "password" : "PASSWORD_SMTP",
        "from" : "admin@arsiva.id",
        "from_name" : "Arsiva",
        "otp_ttl_minutes" : 15,
        "otp_max_attempts" : 5,
        "otp_resend_cooldown_seconds" : 60,
        "reset_password_url" : "https://arsiva.id/reset-password",
        "group_invite_url" : "https://arsiva.id/join-group"
    }
}